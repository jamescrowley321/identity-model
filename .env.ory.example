# Provider profile: Ory Network (cloud). Copy to .env.ory (gitignored) and
# fill in from the Ory Console; `make test-integration-ory` sources it.
# In CI these arrive as the TEST_* repository secrets instead (same values as
# py-identity-model's Ory secrets).
TEST_DISCO_ADDRESS=https://<project-slug>.projects.oryapis.com/.well-known/openid-configuration
TEST_CLIENT_ID=
TEST_CLIENT_SECRET=
TEST_SCOPE=
# Leave empty unless the project has a public PKCE client registered.
TEST_PKCE_PUBLIC_CLIENT_ID=
TEST_REDIRECT_URI=
