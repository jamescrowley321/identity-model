# Provider profile: Descope (cloud). Copy to .env.descope (gitignored) and
# fill in from the Descope console (OAuth app with client_credentials grant);
# `make test-integration-descope` sources it. In CI these arrive as the
# DESCOPE_* repository secrets (same values as py-identity-model's).
TEST_DISCO_ADDRESS=https://api.descope.com/<PROJECT_ID>/.well-known/openid-configuration
TEST_CLIENT_ID=
TEST_CLIENT_SECRET=
TEST_SCOPE=openid
# Leave empty unless the project has a public PKCE client registered.
TEST_PKCE_PUBLIC_CLIENT_ID=
TEST_REDIRECT_URI=
